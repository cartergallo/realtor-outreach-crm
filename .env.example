# ============================================================
# Realtor Outreach CRM — Environment Variables
# Copy to .env.local for Next.js, and set in Supabase + Vercel.
# NEVER commit real values. Env vars only — no hardcoded secrets.
# ============================================================

# ---- Public (browser-safe) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Server-only (Next.js route handlers / seed) ----
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Twilio (used in Edge Functions + server routes) ----
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+17045551234   # default; per-user override lives in profile

# ============================================================
# Supabase Edge Function secrets (set via: supabase secrets set KEY=val)
# These are the SAME values, made available to functions:
#   SB_URL                = NEXT_PUBLIC_SUPABASE_URL
#   SB_SERVICE_ROLE_KEY   = SUPABASE_SERVICE_ROLE_KEY
#   TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN
#   ANTHROPIC_API_KEY, ANTHROPIC_MODEL
#   PUBLIC_WEBHOOK_BASE   = your deployed functions URL (for logs)
# ============================================================
